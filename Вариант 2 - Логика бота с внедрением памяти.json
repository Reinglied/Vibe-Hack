    {
      "parameters": {
        "jsCode": "// 1. Получаем все строки из базы\nconst rows = $input.all();\n\n// 2. Форматируем каждое сообщение\nconst formattedMessages = rows.map(item => {\n  // Берем username. Если у пользователя нет юзернейма (бывает в ТГ), берем имя (first_name)\n  const name = item.json.username || item.json.first_name || 'Аноним';\n  \n  // Берем текст сообщения из правильной колонки message_text\n  const message = item.json.message_text || '[Пустое сообщение/Стикер]';\n  \n  return `${name}: ${message}`;\n});\n\n// 3. Склеиваем всё в одну строку с переносами\nconst chatContext = formattedMessages.join('\\n');\n\n// 4. Возвращаем объект для следующих нод\nreturn {\n  chat_context: chatContext,\n  msg_count: rows.length\n};"
      },
