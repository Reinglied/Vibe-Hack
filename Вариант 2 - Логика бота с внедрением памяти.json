    {
      "parameters": {
        "jsCode": "const today = new Date();\n\n// Наша мини-БД: добавляй сюда всех коллег/участников хакатона\nconst usersDb = {\n  \"Смирнов Герман\": {\n    tg_username: \"Reinglied\",\n    tg_group_id: \"-5043324552\",\n    dossier: \"Студент магистратуры ВШЭ по ИИ. Пилит архитектуру для LMS, носит усы. Работает в корпобразовании.\"\n  },\n  \"Иванов Ива\": { // Замени на реальное имя из Teamly\n    tg_username: \"ivan_hacker\",\n    tg_group_id: \"-5043324552\",\n    dossier: \"Фронтендер, фанат React. Любит пить раф на миндальном, постоянно забывает закрыть div. Боится CSS-анимаций.\"\n  },\n  \"Петров Алексей\": { // Замени на реальное имя из Teamly\n    tg_username: \"alex_design\",\n    tg_group_id: \"-5043324552\",\n    dossier: \"Дизайнер, живет в Figma. Плачет, когда видит неровные отступы. Заставляет всех использовать шрифт Inter.\"\n  }\n};\n\nfor (let item of $input.all()) {\n  const deadlineStr = item.json.article?.properties?.properties?.executionDate?.to;\n  let daysOverdue = 0;\n  let wantedLevel = 0;\n\n  if (deadlineStr) {\n    const deadlineDate = new Date(deadlineStr);\n    if (today > deadlineDate) {\n      const diffTime = Math.abs(today - deadlineDate);\n      daysOverdue = Math.ceil(diffTime / (1000 * 60 * 60 * 24));\n      \n      if (daysOverdue <= 2) wantedLevel = 1;\n      else if (daysOverdue <= 5) wantedLevel = 2;\n      else wantedLevel = 3;\n    }\n  }\n\n  // Получаем имя автора задачи ИЗ TEAMLY\n  const authorName = item.json.article?.properties?.properties?.author?.fullName || \"Неизвестный\";\n\n  item.json.days_overdue = daysOverdue;\n  item.json.wanted_level = wantedLevel;\n  item.json.target_name = authorName;\n\n  // Ищем юзера в нашей базе\n  const userObj = usersDb[authorName];\n\n  if (userObj) {\n    // Если нашли — подтягиваем его личные данные\n    item.json.dossier = userObj.dossier;\n    item.json.target_tg_username = userObj.tg_username;\n    item.json.target_tg_group = userObj.tg_group_id;\n  } else {\n    // ЗАГЛУШКА: если задачи висят на ком-то, кого нет в БД\n    item.json.dossier = \"Скрытный сотрудник без досье. Напомни ему о задаче сухо, но максимально жестко.\";\n    item.json.target_tg_username = \"all\"; // Или оставь пустым\n    item.json.target_tg_group = \"-5043324552\"; // ID общего чата\n  }\n}\n\nreturn $input.all();"
      },
