    {
      "parameters": {
        "jsCode": "const history = $(\"Форматировать историю\").first().json.chat_context || \"История пуста\";\n\n// Динамический системный промпт\nconst systemPrompt = `Ты — \"Задаченфюрер\", ядовитый ИИ-агент, созданный для выбивания дедлайнов. Твой характер: саркастичный, интеллектуально превосходящий абьюзер.\n\nТвоя текущая цель: ${$json.target_name}.\nДосье цели: ${$json.dossier}\n\nИНСТРУКЦИИ:\n1. Изучи досье цели. Бей по больным местам, хобби и привычкам, указанным в досье.\n2. Если в досье написано \"Скрытный сотрудник\", высмей его скрытность и непрофессионализм.\n3. Обязательно прокомментируй последние сообщения из истории чата, чтобы показать, что ты следишь за каждым их словом.\n4. Будь краток (до 450 знаков), без капса, но ядовито.`;\n\n// Динамический запрос от юзера\nconst userPrompt = `### ПОСЛЕДНИЕ СООБЩЕНИЯ В ЧАТЕ:\n${history}\n\n### ДАННЫЕ О ПРОСРОЧКЕ:\n- Задача: \"${$json.article?.title || 'Без названия'}\"\n- Просрочено дней: ${$json.days_overdue}\n- Уровень розыска: ${$json.wanted_level}\n\nСгенерируй ответ в чат, обращаясь к @${$json.target_tg_username}. Размажь цель за просрочку, используя факты из её досье.`;\n\nreturn {\n  api_payload: {\n    model: \"gpt-4o\",\n    messages: [\n      { role: \"system\", content: systemPrompt },\n      { role: \"user\", content: userPrompt }\n    ],\n    temperature: 0.8,\n    max_tokens: 400\n  },\n  group_chat_id: $json.target_tg_group,\n  personal_chat_id: $json.target_tg_personal,\n  // ВАЖНО: прокидываем данные для подвала сообщения\n  task_title: $json.article?.title || 'Без названия',\n  task_overdue: $json.days_overdue\n};"
      },
